# Copy this file to .env and fill in the values before running the server locally.
# In production (Docker / Docker Compose) pass these as environment variables.

# ── Server ──────────────────────────────────────────────────
PORT=3000

# Optional: serve the admin panel on a separate port so it is only reachable
# through a different URL / internal network. Leave unset to serve admin on PORT.
# ADMIN_PORT=3001

# ── Base URL (used in email links) ──────────────────────────
# Set this to your public domain, e.g. https://ssstylish.sk
BASE_URL=http://localhost:3000

# ── Admin panel ─────────────────────────────────────────────
# REQUIRED: Password for the owner account in the /admin panel.
# Change this to a strong, unique password before deploying.
ADMIN_PASSWORD=changeme

# Optional: Password for a second staff account.
# Leave unset to disable the staff login button.
STAFF_PASSWORD=

# Optional: Display names shown on the login screen.
OWNER_NAME=Owner
STAFF_NAME=Staff

# ── Security ────────────────────────────────────────────────
# REQUIRED: Secret used to sign admin session tokens.
# Use a long random string (e.g. openssl rand -hex 32).
JWT_SECRET=change-this-to-a-long-random-secret

# ── Database ────────────────────────────────────────────────
# Path where the SQLite database file is stored.
# Defaults to ./phone_repair.db when not set.
# DB_PATH=/app/backend/data/phone_repair.db

# ── Shop address (shown in customer emails with a Google Maps link) ────
# SHOP_ADDRESS=Mlynská 1, 010 01 Žilina, Slovakia

# ── SMTP (optional – configure via Admin Panel → Settings) ──
# These can also be set in the Admin Panel and are stored in the DB.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=vas@gmail.com
# SMTP_PASS=app-password
# SMTP_FROM=SSStylish Repair <vas@gmail.com>
